{
  "name": "mooduck",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "db.generate": "pnpm --filter mooduck-server run db.generate",
    "db.migrate": "pnpm --filter mooduck-server run db.migrate",
    "db.push": "pnpm --filter mooduck-server run db.push",
    "db.studio": "pnpm --filter mooduck-server run db.studio",
    "db.push.local": "pnpm --filter mooduck-server run db.push.local",
    "db.migrate.local": "pnpm --filter mooduck-server run db.migrate.local",
    "db.studio.local": "pnpm --filter mooduck-server run db.studio.local",
    "build": "MODE=prod turbo build",
    "dev": "MODE=dev turbo dev",
    "dev.local": "pnpm --filter mooduck-server run dev.local",
    "dev.web": "MODE=dev turbo dev --filter=mooduck-web",
    "dev.server": "MODE=dev turbo dev --filter=mooduck-server",
    "start": "MODE=prod turbo start",
    "start.server": "MODE=prod pnpm --filter mooduck-server start",
    "pm2.start": "pm2 start ecosystem.config.js",
    "pm2.restart": "pm2 reload ecosystem.config.js --update-env",
    "lint": "echo 'lint is not ready yet...'",
    "clean": "turbo clean",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "codecheck": "pnpm run typecheck && pnpm run lint"
  },
  "engines": {
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "5.9.2"
  }
}
